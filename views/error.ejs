<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error - <%= status %></title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <main class="container" style="padding: 40px; text-align: center; max-width: 500px; margin: 0 auto;">
        <div style="font-size: 72px; color: #dc3545; font-weight: bold; margin-bottom: 10px;">
            <%= status %>
        </div>
        
        <h2>Oops! Something went wrong.</h2>
        
        <!-- 只展示安全的、我们在路由里自定义的友好错误信息 -->
        <p style="color: #6c757d; font-size: 18px; margin: 20px 0;">
            <%= message %>
        </p>
        
        <hr style="border: 0; border-top: 1px solid #eee; margin: 30px 0;">
        
        <a href="/products" style="text-decoration: none; color: #007BFF; font-weight: bold;">
            &larr; Return to Product Catalogue
        </a>
    </main>
</body>
</html>