<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Product</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <main class="container" style="padding: 20px; max-width: 600px; margin: 0 auto;">
        <h1>Add Product</h1>

        <hr>

        <% if (errors.length > 0) { %>
            <div class="errors" style="border: 1px solid #dc3545; background-color: #f8d7da; color: #721c24; padding: 12px 16px; border-radius: 8px; margin-bottom: 20px;">
                <ul style="margin: 0; padding-left: 20px;">
                    <% errors.forEach((error) => { %>
                        <li><%= error %></li>
                    <% }) %>
                </ul>
            </div>
        <% } %>

        <form method="POST" action="/products" class="product-form">
            <p>
                <label for="name"><strong>Name</strong></label><br>
                <input type="text" id="name" name="name"
                       value="<%= values.name || '' %>" required
                       style="width: 100%; padding: 8px; margin-top: 4px;">
            </p>

            <p>
                <label for="category"><strong>Category</strong></label><br>
                <input type="text" id="category" name="category"
                       value="<%= values.category || '' %>" required
                       style="width: 100%; padding: 8px; margin-top: 4px;">
            </p>

            <p>
                <label for="brand"><strong>Brand</strong> (optional)</label><br>
                <input type="text" id="brand" name="brand"
                       value="<%= values.brand || '' %>"
                       style="width: 100%; padding: 8px; margin-top: 4px;">
            </p>

            <p>
                <label for="price"><strong>Price</strong></label><br>
                <input type="number" id="price" name="price" step="0.01" min="0"
                       value="<%= values.price || '' %>" required
                       style="width: 100%; padding: 8px; margin-top: 4px;">
            </p>

            <p>
                <label for="stockQuantity"><strong>Stock Quantity</strong></label><br>
                <input type="number" id="stockQuantity" name="stockQuantity" min="0" step="1"
                       value="<%= values.stockQuantity || '' %>" required
                       style="width: 100%; padding: 8px; margin-top: 4px;">
            </p>

            <p>
                <label>
                    <input type="checkbox" name="available"
                           <%= values.available === "on" ? "checked" : "" %>>
                    <strong>Available for sale</strong>
                </label>
            </p>

            <button type="submit"
                    style="background-color: #007BFF; color: white; border: none; padding: 10px 20px; border-radius: 6px; cursor: pointer; font-size: 16px;">
                Create Product
            </button>
        </form>

        <br>
        <a href="/products" style="text-decoration: none; color: #007BFF;">&larr; Back to Catalogue</a>
    </main>
</body>
</html>
